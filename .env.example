# Base URL of the admin API (Phase 2 — BeanPortfolioAdminAPI).
#
# Leave this UNSET and the site serves the hardcoded content in
# src/content/portfolio.ts with no network request.
#
# Set it, and the site fetches GET {VITE_PORTFOLIO_API_URL}/portfolio, mapping
# the response through src/content/adapter.ts. If the request fails it falls
# back to the hardcoded content, so the site can never render blank.
#
# That flip is the entire frontend change needed to go CMS-driven.
#
# VITE_PORTFOLIO_API_URL=https://beanadminapi.azaken.com/api
